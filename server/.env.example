# Copie para .env e ajuste. Não commite o .env com segredos reais.

NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# Obrigatório para /v1/categorize (Plano nuvem)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_MAX_TOKENS=4096

# JWT HS256: npm run token:dev (scripts/issue-dev-token.mjs)
JWT_SECRET=altere-para-um-segredo-longo-aleatorio

# Alternativa dev: tokens estáticos separados por vírgula (não ideal em produção)
API_TOKENS=

# CORS: ex. chrome-extension://SEU_EXTENSION_ID,https://seu-dominio.com
CORS_ORIGINS=

MAX_EMAILS_PER_REQUEST=30
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=60

APP_VERSION=1.0.0
GIT_SHA=dev
